# Copy to ".env". Leave blank to run in OFFLINE / template mode (still fully functional).
ANOMALY_LLM_PROVIDER=anthropic
# Anthropic
ANTHROPIC_API_KEY=
ANOMALY_LLM_MODEL=claude-sonnet-4-6
# Groq (free key from https://console.groq.com)
GROQ_API_KEY=
ANOMALY_GROQ_MODEL=llama-3.3-70b-versatile
# Shared (optional)
ANOMALY_LLM_MAX_TOKENS=1200
ANOMALY_LLM_TEMPERATURE=0.2
